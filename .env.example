# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hafif_portfolio?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-at-least-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-at-least-32-characters-long"
AUTH_URL="http://localhost:3000"

# ─── GitHub Integration (optional) ────────────────────────────────────────────
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN="ghp_your_personal_access_token"
GITHUB_USERNAME="hafifsaputra"

# ─── Email Notifications (optional) ───────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"
CONTACT_EMAIL="hafif@example.com"
